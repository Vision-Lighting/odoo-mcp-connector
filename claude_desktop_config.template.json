{
  "mcpServers": {
    "odoo-live": {
      "command": "C:\\PATH\\TO\\python.exe",
      "args": [
        "C:\\PATH\\TO\\Odoo Connector\\server.py"
      ],
      "env": {
        "ODOO_URL": "https://YOUR_LIVE_INSTANCE.odoo.com",
        "ODOO_DB": "YOUR_LIVE_DB",
        "ODOO_USERNAME": "YOUR_EMAIL@yourcompany.com",
        "ODOO_API_KEY": "YOUR_LIVE_API_KEY",
        "ODOO_MODE": "live_rw"
      }
    }
  }
}
